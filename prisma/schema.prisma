generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String?            @unique
  emailVerified DateTime?
  chips         Int                @default(1000)
  image         String?
  accounts      Account[]
  pokerSessions PokerSessionUser[]
  sessions      Session[]
}

model PokerSession {
  id          String             @id @default(cuid())
  name        String
  private     Boolean            @default(false)
  status      String
  createdAt   DateTime           @default(now())
  createdBy   String
  gameState   Json?
  sessionCode Int                @unique
  users       PokerSessionUser[]
}

model PokerSessionUser {
  id             String       @id @default(cuid())
  userId         String
  pokerSessionId String
  chips          Int
  seatNumber     Int?
  isActive       Boolean      @default(true)
  checked        Boolean      @default(true)
  maxed          Boolean      @default(true)
  setChips       Int          @default(0)
  valid          Boolean      @default(true)
  yourTurn       Boolean      @default(true)
  pokerSession   PokerSession @relation(fields: [pokerSessionId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
